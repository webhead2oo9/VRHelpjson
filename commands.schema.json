{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["name", "description"],
  "anyOf": [
    { "required": ["embed"] },
    { "required": ["embeds"] },
    { "required": ["pages"] }
  ],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9_-]{1,32}$"
    },
    "description": { "type": "string" },
    "ephemeral": { "type": "boolean" },
    "embed": { "$ref": "#/$defs/embed" },
    "embeds": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/embed" }
    },
    "pages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "title"],
        "anyOf": [
          { "required": ["embed"] },
          { "required": ["embeds"] }
        ],
        "properties": {
          "name": { "type": "string" },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "emoji": { "type": "string" },
          "embed": { "$ref": "#/$defs/embed" },
          "embeds": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "#/$defs/embed" }
          }
        }
      }
    }
  },
  "$defs": {
    "embed": {
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "url": { "type": ["string", "null"] },
        "color": { "type": ["integer", "null"] },
        "fields": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "value"],
            "properties": {
              "name": { "type": "string" },
              "value": { "type": "string" },
              "inline": { "type": "boolean" }
            }
          }
        },
        "thumbnail": {
          "type": "object",
          "properties": {
            "url": { "type": "string" }
          }
        },
        "image": {
          "type": "object",
          "properties": {
            "url": { "type": "string" }
          }
        },
        "footer": {
          "type": "object",
          "properties": {
            "text": { "type": "string" }
          }
        }
      }
    }
  }
}
