{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "VR help-center custom command",
  "description": "One help-center command per file; the filename (without .json) must equal 'name'. Block-based format 2 only — see AUTHORING.md.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "format",
    "name",
    "description"
  ],
  "anyOf": [
    {
      "required": [
        "blocks"
      ]
    },
    {
      "required": [
        "pages"
      ]
    }
  ],
  "properties": {
    "format": {
      "const": 2
    },
    "name": {
      "$ref": "#/definitions/commandName"
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100
    },
    "accent_color": {
      "$ref": "#/definitions/color"
    },
    "thumbnail_url": {
      "$ref": "#/definitions/thumbnailUrl"
    },
    "blocks": {
      "$ref": "#/definitions/blockList"
    },
    "pages": {
      "type": "array",
      "minItems": 1,
      "maxItems": 25,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "blocks"
        ],
        "properties": {
          "name": {
            "$ref": "#/definitions/commandName"
          },
          "title": {
            "type": "string",
            "maxLength": 100
          },
          "description": {
            "type": "string",
            "maxLength": 100
          },
          "accent_color": {
            "$ref": "#/definitions/color"
          },
          "thumbnail_url": {
            "$ref": "#/definitions/thumbnailUrl"
          },
          "blocks": {
            "$ref": "#/definitions/blockList"
          }
        }
      }
    }
  },
  "definitions": {
    "blockList": {
      "type": "array",
      "minItems": 1,
      "maxItems": 30,
      "items": {
        "$ref": "#/definitions/block"
      }
    },
    "block": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type",
            "text"
          ],
          "properties": {
            "type": {
              "const": "heading"
            },
            "text": {
              "type": "string",
              "minLength": 1,
              "maxLength": 256
            },
            "url": {
              "$ref": "#/definitions/httpUrl"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type",
            "text"
          ],
          "properties": {
            "type": {
              "const": "text"
            },
            "text": {
              "type": "string",
              "minLength": 1,
              "maxLength": 3800
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type",
            "name",
            "value"
          ],
          "properties": {
            "type": {
              "const": "field"
            },
            "name": {
              "type": "string",
              "minLength": 1,
              "maxLength": 256
            },
            "value": {
              "type": "string",
              "minLength": 1,
              "maxLength": 1024
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type"
          ],
          "properties": {
            "type": {
              "const": "divider"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type",
            "urls"
          ],
          "properties": {
            "type": {
              "const": "images"
            },
            "urls": {
              "type": "array",
              "minItems": 1,
              "maxItems": 10,
              "items": {
                "$ref": "#/definitions/httpUrl"
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type",
            "text"
          ],
          "properties": {
            "type": {
              "const": "small"
            },
            "text": {
              "type": "string",
              "minLength": 1,
              "maxLength": 1024
            }
          }
        }
      ]
    },
    "commandName": {
      "type": "string",
      "pattern": "^[a-z0-9_-]{1,32}$"
    },
    "color": {
      "type": "integer",
      "minimum": 0,
      "maximum": 16777215
    },
    "httpUrl": {
      "type": "string",
      "pattern": "^https?://"
    },
    "thumbnailUrl": {
      "type": "string",
      "pattern": "^https?://",
      "maxLength": 1024
    }
  }
}
